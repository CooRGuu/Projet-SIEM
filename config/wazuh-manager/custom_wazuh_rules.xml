<?xml version="1.0" encoding="UTF-8"?>
<ossec_config>
  <!-- Custom rules added for the stage project -->
  <rules>
    <!-- Rule 5601 – PowerShell Suspicious Execution (T1064) -->
    <rule id="5601" level="8" frequency="1">
      <if_sid>5600</if_sid>
      <field name="program_name">powershell.exe</field>
      <match>ExecutionPolicy Bypass</match>
      <description>PowerShell suspicious execution: bypassing execution policy and running external script.</description>
      <group>powershell,</group>
    </rule>

    <!-- Rule 5802 – Registry Modification (T1112) -->
    <rule id="5802" level="7" frequency="1">
      <if_sid>5702</if_sid>
      <field name="program_name">reg.exe</field>
      <match>add</match>
      <description>Unexpected registry modification detected (potential persistence technique).</description>
      <group>registry,</group>
    </rule>

    <!-- Rule 5901 – Service Creation (T1543) -->
    <rule id="5901" level="8" frequency="1">
      <if_sid>5900</if_sid>
      <field name="program_name">sc.exe</field>
      <match>create</match>
      <description>Creation of a new Windows service detected – possible malicious persistence.</description>
      <group>service,</group>
    </rule>
  <!-- Rule 6000 – SCA Scan Completion (CIS Benchmark) -->
  <rule id="6000" level="5" frequency="1">
    <if_sid>5999</if_sid>
    <field name="program_name">wazuh-modulesd</field>
    <match>sca: INFO: Evaluation finished</match>
    <description>SCA scan completed successfully – indicates CIS benchmark evaluation finished.</description>
    <group>sca,</group>
  </rule>

  <!-- Rule 5700 – Account Lockout Event (Windows Security) -->
  <rule id="5700" level="7" frequency="1">
    <if_sid>5710</if_sid>
    <field name="event_id">4740</field>
    <description>Windows account lockout detected (Event ID 4740) – potential brute‑force attempt.</description>
    <group>windows,security,</group>
  </rule>

  <!-- Rule 5500 – MSI Installation of Wazuh Agent -->
  <rule id="5500" level="5" frequency="1">
    <if_sid>5499</if_sid>
    <field name="program_name">msiexec.exe</field>
    <match>install</match>
    <field name="full_path">C:\\Program Files (x86)\\ossec-agent\\wazuh-agent-4.10.4-1.msi</field>
    <description>Installation of Wazuh agent MSI detected – useful for auditing deployments.</description>
    <group>software,installation,</group>
  </rule>

  <!-- Rule 5400 – Tailscale Tunnel Establishment -->
  <rule id="5400" level="4" frequency="1">
    <if_sid>5399</if_sid>
    <field name="program_name">tailscale</field>
    <match>Ready</match>
    <description>Tailscale tunnel established – indicates overlay network is up.</description>
    <group>network,</group>
  </rule>

  <!-- Rule 5602 – Suspicious PowerShell Script Block Logging -->
  <rule id="5602" level="8" frequency="1">
    <if_sid>5600</if_sid>
    <field name="event_id">4104</field>
    <description>PowerShell script block logging detected – possible malicious script execution.</description>
    <group>powershell,</group>
  </rule>

  </rules>
</ossec_config>
